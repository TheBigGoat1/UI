DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/insidr
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES=7d

# Optional in dev — Vite proxies /api/v1 → localhost:3001 automatically
VITE_API_URL=http://localhost:3001/api/v1

# NewsAPI.org — https://newsapi.org/ (100 requests/day free)
NEWSAPI_API_KEY=405f4009adfa4787be05b4d4c626d615

# NewsData.io — https://newsdata.io/ (crypto news endpoint)
NEWSDATA_API_KEY=pub_a6e741e07f6a4cf7b44b26187b3eed18 
# CryptoPanic v2 — https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your-cryptopanic-auth-token
CRYPTOPANIC_API_PLAN=developer

# CoinDesk — RSS only (no key); fetched automatically

# Optional — live economic calendar enrichment
# FINNHUB_API_KEY=your-finnhub-key
# FMP_API_KEY=your-financial-modeling-prep-key

# Optional legacy fallback (paid GNews — not required)
# GNEWS_API_KEY=
# VITE_GNEWS_API_KEY=

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
# Required for Checkout (or set Public business name in Stripe Dashboard)
STRIPE_BUSINESS_NAME=Insidr
STRIPE_SUPPORT_EMAIL=support@yourdomain.com
# Match your Vite port (5173 or 5174)
FRONTEND_URL=http://localhost:5173
# Optional: local trial without Stripe in development
# ALLOW_DEV_BILLING=true

# Anthropic — https://console.anthropic.com/ (AI trade ideas + chat)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Admin oversight allowlist (comma-separated)
# These emails are always super admins and can access /admin/login
ADMIN_EMAILS=owner@yourdomain.com,security@yourdomain.com

# Realtime + cache (free tier example: Upstash/Redis Cloud)
# REDIS_URL=redis://default:password@host:port

# Alerts email channel (optional free-tier test mode)
# RESEND_API_KEY=re_xxx
# ALERTS_FROM_EMAIL=alerts@yourdomain.com

# Twelve Data — https://twelvedata.com/ (optional FX/commodity prices)
TWELVE_DATA_API_KEY=254889f5b42e40769f0130054d40ecb5

# Dev: allow any signed-in user to run backtests (production uses Pro/Elite)
# ALLOW_FREE_BACKTEST=true
