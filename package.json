{
  "name": "mrkt-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "server": "node server/index.js",
    "db:setup": "node server/scripts/setup-db.mjs",
    "db:seed": "node server/scripts/seed-demo.mjs",
    "db:seed-dashboard": "node server/scripts/seed-dashboard.mjs",
    "db:check": "node server/scripts/check-db.mjs",
    "news:sync": "node server/scripts/sync-news.mjs",
    "calendar:sync": "node server/scripts/sync-calendar.mjs",
    "setup:full": "npm install && npm run db:setup && npm run db:seed",
    "server:kill": "node server/scripts/kill-dev-ports.mjs",
    "dev:all": "node server/scripts/kill-dev-ports.mjs && concurrently \"npm run server\" \"npm run dev\"",
    "stripe:check": "node server/scripts/stripe-check.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.3",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.560.0",
    "pg": "^8.13.3",
    "pnpm": "^10.25.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.11.0",
    "react-server-dom-parcel": "^19.2.3",
    "react-server-dom-webpack": "^19.2.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.14",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.19",
    "vite": "^7.2.4"
  }
}
